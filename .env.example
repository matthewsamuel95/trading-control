# Environment Variables for OpenClaw Trading Control Platform
# Copy this file to .env and update with your actual API keys

# =============================================================================
# BASIC CONFIGURATION
# =============================================================================

# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=false
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO
LOG_FILE=
ENABLE_COLORS=true

# CORS settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# OPENCLAW CONFIGURATION
# =============================================================================

# Orchestrator settings
CYCLE_INTERVAL=60
MAX_CONCURRENT_CYCLES=3
CONFIDENCE_THRESHOLD=0.6
RISK_THRESHOLD=0.7

# =============================================================================
# DATABASE CONNECTIONS
# =============================================================================

# Redis (for short-term memory)
REDIS_URL=redis://localhost:6379

# PostgreSQL (for persistent memory)
POSTGRES_URL=postgresql://user:pass@localhost/trading

# =============================================================================
# API KEYS (ADD YOUR ACTUAL KEYS HERE)
# =============================================================================

# Alpha Vantage API Key (for stock quotes, historical data)
# Get free key from: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# News API Key (for news sentiment analysis)
# Get free key from: https://newsapi.org/register
NEWS_API_KEY=your_news_api_key_here

# Financial Modeling Prep API Key (for financial statements, fundamentals)
# Get free key from: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# =============================================================================
# OPTIONAL: OBSERVABILITY KEYS
# =============================================================================

# Langfuse (for observability tracking)
# Get from: https://langfuse.com/
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Use fallback storage when Redis/PostgreSQL not available
USE_FALLBACK_STORAGE=true

# Enable debug mode for development
ENABLE_DEBUG_LOGGING=true
LOG_LEVEL=INFO
LOG_FILE=logs/trading_platform.log
LOG_COLORS=true

# Mission Control Configuration
MISSION_CONTROL_HOST=localhost
MISSION_CONTROL_PORT=3000
MISSION_CONTROL_API_KEY=dev_mission_control_api_key

# Langfuse Configuration
LANGFUSE_PUBLIC_KEY=dev_public_key
LANGFUSE_SECRET_KEY=dev_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# Agent Configuration
AGENT_REGISTRY_PATH=/agents
AGENT_TIMEOUT_SECONDS=300
MAX_CONCURRENT_AGENTS=10
AGENT_POOL_SIZE=5

# Observability Configuration
EVENT_BATCH_SIZE=100
METRICS_RETENTION_DAYS=30
TRACE_SAMPLE_RATE=1.0
